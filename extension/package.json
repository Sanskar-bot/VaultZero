{
  "name": "@vaultzero/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VaultZero browser extension — Chrome + Firefox Manifest V3",
  "scripts": {
    "build":     "node esbuild.config.js",
    "build:prod":"NODE_ENV=production node esbuild.config.js",
    "watch":     "WATCH=true node esbuild.config.js",
    "typecheck": "tsc --noEmit",
    "clean":     "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@vaultzero/core": "*",
    "react":           "^18.3.1",
    "react-dom":       "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome":          "^0.0.270",
    "@types/react":           "^18.3.12",
    "@types/react-dom":       "^18.3.1",
    "@types/node":            "^22.10.0",
    "esbuild":                "^0.24.0",
    "typescript":             "^5.7.2"
  }
}
