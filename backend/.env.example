# ═══════════════════════════════════════════════════════════════
# VaultZero Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in real values.
# NEVER commit .env to version control — it is in .gitignore.
# ═══════════════════════════════════════════════════════════════

# PostgreSQL connection string
# Local:   postgresql://user:password@localhost:5432/vaultzero
# Railway: set automatically via Railway's Postgres plugin
DATABASE_URL=postgresql://user:password@localhost:5432/vaultzero

# JWT signing secret — MUST be at least 32 characters (recommended: 64 random bytes)
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Server REFUSES TO START if this is shorter than 32 characters.
JWT_SECRET=replace-with-a-random-64-byte-hex-string-never-commit-this-value

# Server port (Railway sets this automatically — leave as 3000 for local dev)
PORT=3000

# The frontend origin allowed by CORS. Only this exact origin can call the API.
# Never use * — that allows any website to make credentialed requests.
# Local:   http://localhost:5173
# Prod:    https://your-extension-id.chromiumapp.org
ALLOWED_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development
