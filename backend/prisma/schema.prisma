// ═══════════════════════════════════════════════════════════════════
// VaultZero — Prisma Schema
// ═══════════════════════════════════════════════════════════════════
//
// SECURITY INVARIANTS — enforced by schema design:
//
// 1. NO column ever holds a plaintext password, KEK, or vault key.
// 2. argon2Salt is stored so any device can re-derive the KEK from
//    the master password. Without the master password, the salt alone
//    is useless.
// 3. wrappedVaultKey is AES-256-GCM encrypted — only the client can
//    unwrap it using the KEK derived from the master password.
// 4. VaultBlob.ciphertext is an opaque AES-256-GCM blob. The server
//    treats it as bytes and cannot decrypt it.
// 5. RefreshToken.tokenHash is SHA-256 of the raw token. The raw token
//    is shown to the client once and never persisted.
// 6. recoveryHash is SHA-256 of the recovery phrase. The phrase itself
//    is never stored anywhere.
// ═══════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  argon2Salt      String         // base64-encoded random salt — returned to client on login
  wrappedVaultKey String         // vault key encrypted with master-password KEK, base64-encoded
  wrappedVaultKeyForRecovery String? // vault key encrypted with recovery KEK — null until recovery setup
  recoveryHash    String?        // SHA-256 of recovery phrase, nullable until user sets up recovery
  createdAt       DateTime       @default(now())

  vaultBlob     VaultBlob?
  devices       Device[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
}

model VaultBlob {
  id         String   @id @default(uuid())
  userId     String   @unique                // one vault per user
  ciphertext String   @db.Text              // entire AES-256-GCM encrypted vault blob (IV prepended)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  deviceName String
  publicKey  String?  @db.Text             // device public key for future E2E device sync
  lastSeen   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique              // SHA-256 hex of raw token — raw token never stored
  expiresAt DateTime
  used      Boolean  @default(false)      // single-use: set true when rotated or on logout
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String
  deviceId  String?                        // nullable: some actions have no device context
  action    AuditAction
  ipAddress String                         // real client IP (after X-Forwarded-For extraction)
  createdAt DateTime    @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id])

  @@index([userId, createdAt])
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  VAULT_PULL
  VAULT_PUSH
  PASSWORD_CHANGED
  RECOVERY_USED
}
